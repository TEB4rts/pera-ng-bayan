{
  "name": "pera-ng-bayan",
  "version": "1.0.0",
  "description": "Philippine government spending intelligence system — auto-compiles all public spending data and flags corruption patterns",
  "main": "src/index.js",
  "scripts": {
    "ingest:all": "node ingestion/run-all.js",
    "ingest:philgeps": "node ingestion/sources/philgeps/awards.js",
    "ingest:coa": "node ingestion/sources/coa/scraper.js",
    "ingest:dbm": "node ingestion/sources/dbm/budget.js",
    "ingest:foi": "node ingestion/sources/foi/disclosures.js",
    "analyze:flags": "node intelligence/run-all-flags.js",
    "analyze:overpricing": "node intelligence/flags/overpricing-flags.js",
    "api": "node api/server.js",
    "report:daily": "node api/reports/daily-digest.js",
    "export:json": "node api/export.js --format json",
    "export:csv": "node api/export.js --format csv",
    "test": "jest",
    "lint": "eslint ."
  },
  "keywords": [
    "philippines",
    "government",
    "transparency",
    "procurement",
    "corruption",
    "philgeps",
    "coa",
    "dbm",
    "open-data",
    "accountability"
  ],
  "author": "Pera ng Bayan contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/pera-ng-bayan.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "js-yaml": "^4.1.0",
    "node-cron": "^3.0.3",
    "pdf-parse": "^1.1.1",
    "better-sqlite3": "^9.4.3",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "fast-csv": "^4.3.6",
    "node-fetch": "^3.3.2",
    "xml2js": "^0.6.2",
    "fuse.js": "^7.0.0",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "table": "^6.8.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "eslint": "^8.56.0",
    "nodemon": "^3.0.2"
  }
}
